JAVA_VERSION=21

# Porte specifiche per ogni servizio
AUTH_PORT=8081
BACKEND_PORT=8082
GATEWAY_PORT=8080

# Database (MariaDB)
DB_URL=jdbc:mariadb://marketplace-db:3306/marketplace?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USER=marketuser
DB_PASSWORD=marketpass
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=marketplace
MARIADB_USER=marketuser
MARIADB_PASSWORD=marketpass

# JWT
JWT_SECRET=super-secret-key-super-secret-key-123456
JWT_EXPIRATION=86400000

AUTH_SERVICE_URL=http://marketplace-auth:8081
API_SERVICE_URL=http://marketplace-backend-v2:8082

GATEWAY_URL=http://marketplace-gateway:8080
HOST_GATEWAY=marketplace-gateway